"""
handlers/start_command.py
-----------------------------
حداقلیِ لازم برایِ «/start» - این ربات فقط یک کار می‌کنه (پخشِ موزیک در
ویس‌چت)، پس این پیام هم فقط همون رو توضیح می‌ده.
"""

from telebot.types import Message

from core import bot

START_TEXT = (
    "🎵 <b>سلام!</b>\n\n"
    "من یک ربات پخشِ موزیک برای ویس‌چتِ گروه‌ها هستم.\n\n"
    "برای استفاده:\n"
    "۱. من رو به گروه اضافه کن (خودکار مالکِ اصلیِ همون گروه می‌شی)\n"
    "۲. یکی از یوزربات‌های استخر رو هم به همون گروه اضافه کن (نگاه کن به setup.md)\n"
    "۳. رویِ یک فایلِ صوتی ریپلای کن و بنویس «پخش»، یا بنویس «پخش آهنگ &lt;اسم/لینک&gt;»\n\n"
    "دستورهایِ کنترل: «هاب»، «مکث»، «ادامه پخش»، «بعدی»، «پایان پخش»، «شافل»\n"
    "دستورهایِ نقش: «افزودن مالک دو»، «افزودن ادمین»، «مدیران»\n\n"
    "فقط مالکِ اصلی/مالکِ ۲/ادمینِ هر گروه (و ادمینِ کلِ ربات) اجازه‌یِ کنترلِ موزیک دارند."
)


@bot.message_handler(commands=["start"])
async def handle_start(message: Message):
    await bot.reply_to(message, START_TEXT)